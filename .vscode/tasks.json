{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/CardGame.Api/CardGame.Api.csproj",
        "/nr:false"
      ],
      "options": {
        "env": {
          "MSBUILDDISABLENODEREUSE": "1",
          "TEMP": "${workspaceFolder}\\.vscode\\.tmp",
          "TMP": "${workspaceFolder}\\.vscode\\.tmp"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "client: dev",
      "type": "npm",
      "script": "dev",
      "path": "client",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http://localhost:3000/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
